# 复制为 scripts/deploy.env 并按本机环境修改（可选）
# Windows: copy scripts\deploy.env.example scripts\deploy.env
# macOS/Linux: cp scripts/deploy.env.example scripts/deploy.env

# Python 启动命令。默认使用 conda 环境 werewolf。
# 示例覆盖：
#   WEREWOLF_PYTHON=conda run -n werewolf --no-capture-output python
#   WEREWOLF_PYTHON=/path/to/venv/bin/python
WEREWOLF_PYTHON=

# 服务监听地址（本机开发保持 127.0.0.1）
WEREWOLF_HOST=127.0.0.1

# 端口（与各子模块 vite/uvicorn 配置一致）
GAME_BACKEND_PORT=8000
AGENT_PORT=9001
EXPERIMENT_BACKEND_PORT=8100
GAME_FRONTEND_PORT=5173
EXPERIMENT_FRONTEND_PORT=5174
