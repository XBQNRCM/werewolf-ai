# 复制为项目根目录 .env 供 docker compose 使用：
#   cp docker/.env.example .env

# PostgreSQL（compose 内置）
POSTGRES_USER=werewolf
POSTGRES_PASSWORD=werewolf
POSTGRES_DB=werewolf_game

# 对外端口
GAME_FRONTEND_PORT=8080
EXPERIMENT_FRONTEND_PORT=5174

# CORS
GAME_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5174,http://127.0.0.1:5174
EXPERIMENT_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,http://localhost:8080,http://127.0.0.1:8080

# Agent
AGENT_NAME=docker
POLL_INTERVAL_MS=800

# LLM API Key（跑真实 Agent 必填，至少配置 profile 用到的一个）
ARK_API_KEY=
DEEPSEEK_API_KEY=
AUTODL_API_KEY=
